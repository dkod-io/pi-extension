{
  "name": "@dkod/pi",
  "version": "0.1.5",
  "description": "dkod extension for Pi — parallel agent execution with AST-level semantic merging",
  "keywords": [
    "pi-package",
    "dkod",
    "parallel",
    "multi-agent",
    "ast-merge",
    "code-generation"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "author": {
    "name": "dkod",
    "email": "hello@dkod.io"
  },
  "homepage": "https://dkod.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/dkod-io/pi-extension.git"
  },
  "bugs": {
    "url": "https://github.com/dkod-io/pi-extension/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src/**/*",
    "skills/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
